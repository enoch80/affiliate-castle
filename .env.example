# Database
DATABASE_URL="postgresql://affiliate:password@postgres:5432/affiliatecastle"

# Redis (BullMQ)
REDIS_URL="redis://redis:6379"

# Auth
NEXTAUTH_SECRET="replace-with-random-64-char-string"
NEXTAUTH_URL="https://app.yourdomain.com"

# Admin credentials (single owner — use scripts/hash-password.js to generate hash)
ADMIN_EMAIL="you@yourdomain.com"
ADMIN_PASSWORD_HASH="bcrypt-hash-here"

# SMTP warm-up start date (ISO 8601 — set when you first configure Postfix)
SMTP_WARMUP_START_DATE="2026-01-01"

# Ollama (local)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.3:70b"

# Listmonk (self-hosted email)
LISTMONK_URL="http://localhost:9000"
LISTMONK_USERNAME="listmonk"
LISTMONK_PASSWORD="listmonk"

# SMTP (Postfix local)
SMTP_HOST="localhost"
SMTP_PORT=25
SMTP_FROM_NAME="Your Brand"
SMTP_FROM_EMAIL="hello@yourdomain.com"

# Domain
APP_DOMAIN="app.yourdomain.com"
TRACKING_DOMAIN="t.yourdomain.com"

# Encryption key for stored credentials (32 hex bytes)
CREDENTIAL_ENCRYPTION_KEY="replace-with-64-char-hex-string"

# IndexNow
INDEXNOW_KEY="replace-with-your-indexnow-key"

# CAN-SPAM compliance
COMPANY_ADDRESS="Your Address, City, Country"
